# Copy to .env and fill in. Restart: npx expo start --clear
# https://docs.expo.dev/guides/environment-variables/

# Deploy (Render, etc.): set the same keys in the host dashboard; EXPO_PUBLIC_*
# values are baked in when `expo export` runs, not from a committed .env file.

# Production web origin (HTTPS, no trailing slash) — Share links & study-duel URLs.
# Firebase Auth → Authorized domains must include this host (e.g. dissertationgames.onrender.com).
EXPO_PUBLIC_WEB_APP_URL=https://dissertationgames.onrender.com

# Firebase (from Firebase console → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# OpenAI (native iOS/Android trivia) — baked in at `expo export` / EAS build time.
EXPO_PUBLIC_OPENAI_API_KEY=
# Optional: compatible API / Azure (must end with …/v1 for standard OpenAI shape)
# EXPO_PUBLIC_OPENAI_BASE_URL=https://api.openai.com/v1
# EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini
# Web/static export: browsers cannot call api.openai.com (CORS). Point to your HTTPS function:
# POST body JSON { "difficulty": "easy"|"medium"|"hard", "count": number }
# Response JSON { "questions": [ { "question", "options": [4 strings], "answer" } ] }
# EXPO_PUBLIC_TRIVIA_GENERATE_URL=

# Optional: hosted WebView games (see web-games/HOW_TO_VERCEL.md)
EXPO_PUBLIC_SNAKE_URL=
EXPO_PUBLIC_GEM_MATCH_URL=

# Vendor multiplayer arcade (see vendor/ARCADE_LOCAL_DEV.md)
EXPO_PUBLIC_VENDOR_CHESS_URL=http://localhost:3000
EXPO_PUBLIC_VENDOR_LUDO_URL=http://localhost:3000
