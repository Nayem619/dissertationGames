# Copy to .env and fill in. Restart: npx expo start --clear
# https://docs.expo.dev/guides/environment-variables/

# Deploy (Render, etc.): set the same keys in the host dashboard; EXPO_PUBLIC_*
# values are baked in when `expo export` runs, not from a committed .env file.

# Production web origin (HTTPS, no trailing slash) — Share links & study-duel URLs.
# Firebase Auth → Authorized domains must include this host (e.g. dissertationgames.onrender.com).
EXPO_PUBLIC_WEB_APP_URL=https://dissertationgames.onrender.com

# Firebase (from Firebase console → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# OpenAI (trivia fallback generation) — use a server/proxy in production if possible
EXPO_PUBLIC_OPENAI_API_KEY=

# Optional: hosted WebView games (see web-games/HOW_TO_VERCEL.md)
EXPO_PUBLIC_SNAKE_URL=
EXPO_PUBLIC_GEM_MATCH_URL=
