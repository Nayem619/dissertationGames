rules_version = '2';

// Dissertation Games — mirrors lib/* Firestore usage.
// Deploy: Firebase Console → Firestore → Rules, or `firebase deploy --only firestore:rules`
// Tighten multiplayer / async_challenge / study_duels updates before production traffic.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // --- Multiplayer lobby + realtime game state ---
    match /multiplayer_rooms/{roomId} {
      // Live listeners + joins need read access with the room code.
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid;
      // Host or seated guest applies moves; joining user sets guestUid once.
      allow update: if signedIn() && (
        resource.data.hostUid == request.auth.uid
        || resource.data.guestUid == request.auth.uid
        || (
          resource.data.guestUid == null
          && request.resource.data.hostUid == resource.data.hostUid
          && request.resource.data.guestUid == request.auth.uid
        )
      );
      allow delete: if false;

      match /messages/{msgId} {
        function room() {
          return get(/databases/$(database)/documents/multiplayer_rooms/$(roomId));
        }
        allow read: if signedIn() && (
          room().data.hostUid == request.auth.uid
          || room().data.guestUid == request.auth.uid
        );
        allow create: if signedIn()
          && request.resource.data.senderUid == request.auth.uid
          && (
            room().data.hostUid == request.auth.uid
            || room().data.guestUid == request.auth.uid
          );
        allow update, delete: if false;
      }
    }

    // --- Public gamer tag (lib/socialProfile.js) ---
    match /public_profiles/{uid} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    match /username_registry/{name} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // --- Friends (lib/friends.js) ---
    match /friend_requests/{reqId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow update: if false;
    }

    match /friends_pairs/{pairId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.members;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.members;
      allow delete: if signedIn()
        && request.auth.uid in resource.data.members;
      allow update: if false;
    }

    // --- Leaderboards & scores ---
    match /scores/{scoreId} {
      // Leaderboard UI reads the whole collection; keep scores non-secret.
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /leaderboards/{gameId}/players/{userId} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // --- Research / export (lib/dissertation.js) ---
    match /research_events/{eid} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // --- Async challenges (lib/challenges.js) ---
    match /async_challenges/{cid} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.issuerUid == request.auth.uid;
      // Issuer may edit · acceptor stamps acceptedByUid (lib/challenges.js softAcceptChallenge).
      allow update: if signedIn() && (
        resource.data.issuerUid == request.auth.uid
        || (
          resource.data.status == 'open'
          && resource.data.acceptedByUid == null
          && request.resource.data.acceptedByUid == request.auth.uid
          && request.resource.data.status == 'attempted'
        )
      );
      allow delete: if false;
    }

    // --- Study pairwise duels (lib/studyDuels.js) ---
    match /study_duels/{duelId} {
      allow read: if signedIn() && (
        resource.data.status == 'open'
        || resource.data.challengerUid == request.auth.uid
        || resource.data.responderUid == request.auth.uid
      );
      allow create: if signedIn()
        && request.resource.data.challengerUid == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.challengerUid == request.auth.uid
        || resource.data.responderUid == request.auth.uid
        || (
          resource.data.status == 'open'
          && !resource.data.keys().hasAny(['responderUid'])
          && request.resource.data.challengerUid == resource.data.challengerUid
          && request.resource.data.responderUid == request.auth.uid
          && request.resource.data.status == 'paired'
        )
      );
      allow delete: if false;
    }

    // --- Finished online matches history (lib/matchHistory.js) ---
    match /online_matches/{mid} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.participantUids;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantUids;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
