rules_version = '2';

// Firebase Storage rules (constants/firebase.js exports `storage`; app has no uploads yet).
// Deploy: Firebase Console → Storage → Rules, or `firebase deploy --only storage`
//
// Uncomment or adapt `profile_avatars` when you add profile images.

service firebase.storage {
  match /b/{bucket}/o {
    match /profile_avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
